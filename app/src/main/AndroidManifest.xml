<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================================
    AndroidManifest.xml - 应用清单文件
    ============================================================================

    作用：
    1. 声明应用的组件（Activity、Service、BroadcastReceiver等）
    2. 定义应用需要的权限
    3. 配置应用的基本信息（名称、图标、主题等）
    4. 指定应用的最低支持版本

    注意：这是 Android 应用的核心配置文件，所有组件都必须在此声明
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        ========================================================================
        权限声明区域
        ========================================================================

        说明：
        - 普通权限：系统自动授予（如 WAKE_LOCK）
        - 危险权限：需要用户手动授权（如 POST_NOTIFICATIONS）
        - 特殊权限：需要特定条件才能使用（如 FOREGROUND_SERVICE_*）
    -->

    <!--
        POST_NOTIFICATIONS - 通知权限（Android 13+ 必需）

        说明：
        - 从 Android 13 (API 33) 开始，应用需要显式请求此权限才能发送通知
        - 本应用使用前台服务，必须显示通知，所以需要此权限
        - 需要在运行时通过代码请求用户授权

        兼容性：
        - Android 12 及以下：不需要此权限
        - Android 13+：必须声明并请求此权限
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        WAKE_LOCK - 唤醒锁权限

        说明：
        - 允许应用阻止 CPU 进入休眠状态
        - 确保后台服务在屏幕关闭时仍能正常运行
        - 防止系统在播报时间前就杀死进程

        用途：
        - 保证 TTS 播报期间 CPU 保持活跃
        - 提高服务的可靠性
    -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
        FOREGROUND_SERVICE - 基础前台服务权限

        说明：
        - 允许应用启动前台服务
        - 前台服务会显示持久性通知，优先级高
        - 不容易被系统杀死
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!--
        FOREGROUND_SERVICE_xxx 前台服务类型

        说明：
        - Android 14 (API 34) 要求前台服务必须声明具体类型
        - 与 foregroundServiceType="specialUse" 配合使用

        重要性：
        - Android 12 + 后台唤醒容易触发前台超时崩溃
        - Android 14+ 必须声明此权限，否则编译报错
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!--
        RECEIVE_BOOT_COMPLETED - 接收开机完成广播权限

        说明：
        - 允许应用接收系统开机完成的广播事件
        - 实现开机自启动功能的核心权限
        - 普通权限，系统自动授予，无需用户手动授权

        用途：
        - 设备重启后自动启动后台服务
        - 确保应用持续运行，无需用户手动打开
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />


    <!--
        ========================================================================
        应用配置区域
        ========================================================================

        application 标签包含应用的所有组件和全局配置

        属性说明：
        - allowBackup: 是否允许应用数据备份（true=允许，false=禁止）
        - icon: 应用图标资源引用
        - label: 应用名称（显示在桌面和设置中）
        - theme: 应用主题样式（此处使用 Material Light 无 ActionBar 主题）
    -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="亮屏报时"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <!--
            ====================================================================
            Activity 组件声明
            ====================================================================

            MainActivity - 主界面 Activity

            功能：
            - 应用的入口点
            - 显示控制界面
            - 管理广播接收器和服务

            属性说明：
            - name: 类名（相对于包名）
            - exported: true 表示可以被其他应用启动（作为 Launcher）
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <!--
                Intent Filter - 意图过滤器

                作用：声明此 Activity 可以响应哪些 Intent

                MAIN + LAUNCHER 组合：
                - 表示这是应用的主入口
                - 会在桌面显示应用图标
                - 用户点击图标时启动此 Activity
            -->
            <intent-filter>
                <!-- 主 Action：应用入口 -->
                <action android:name="android.intent.action.MAIN" />

                <!-- Category：启动器类别 -->
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            ====================================================================
            Service 组件声明
            ====================================================================

            PowerListenerService - 电源键播报服务

            功能：
            - 接收亮屏事件并播报时间
            - 使用 TTS 进行中文语音播报
            - 作为前台服务运行，降低被杀死的概率

            属性说明：
            - name: 服务类名（相对于包名）
            - exported: false 表示只能被本应用启动（安全性更好）
            - foregroundServiceType: 前台服务类型（Android 14+ 必需）
            - <property>标签是前台服务类型的说明
            - android:permission="android.permission.BIND_FOREGROUND_SERVICE"
               * 限制第三方应用随意绑定前台服务，只允许系统进程绑定，安全加固属性；
        -->
        <service
            android:name=".PowerListenerService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_FOREGROUND_SERVICE">
            <property
                android:name="android.app.PROPERTY_FOREGROUND_SERVICE_SPECIAL_USE_DESCRIPTION"
                android:value="亮屏后语音播报时间、日期、星期、农历、电量，需要后台常驻监听电源键事件，不属于媒体播放或数据同步等标准类型"/>

        </service>

        <!--
            ====================================================================
            BootReceiver - 开机自启动广播接收器
            ====================================================================

            功能：
            - 监听系统开机完成事件（BOOT_COMPLETED）
            - 设备重启后自动启动 PowerListenerService
            - 确保应用无需手动打开即可持续运行

            属性说明：
            - name: 接收器类名（相对于包名）
            - exported: true 表示可以接收系统广播（必需）
            - android:directBootAware="true"
              * 开机输入锁屏密码前也能收到广播，避免重启后没解锁不启动服务

            Intent Filter：
            - 监听 BOOT_COMPLETED 事件（开机完成）
            - 可选监听 QUICKBOOT_POWERON（快速启动）
        -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:directBootAware="true">

            <!--
                Intent Filter - 意图过滤器

                作用：声明此接收器监听的广播类型

                BOOT_COMPLETED：
                - 系统开机完成后触发的广播
                - 所有应用都已加载完毕

                QUICKBOOT_POWERON：
                - 部分设备支持快速启动模式
                - 增强兼容性

                category.DEFAULT
                - 系统开机广播要求必须加，部分原生安卓、一加、谷歌设备不加会收不到广播
            -->
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

    </application>

</manifest>